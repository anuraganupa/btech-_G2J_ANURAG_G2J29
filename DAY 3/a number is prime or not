#include <stdio.h>

int main() {
    int n, i, s = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    if (n <= 1) {
        s = 0;
    } else {
        for (i = 2; i <= n / 2; i++) {
            if (n % i == 0) {
                s = 0;
                break;
            }
        }
    }

    if (s)
        printf("%d is a Prime Number", n);
    else
        printf("%d is Not a Prime Number", n);

    return 0;
}
